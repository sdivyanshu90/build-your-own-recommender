# Never commit real credentials. Prefix nested configuration with RECOMMENDER__.
RECOMMENDER__ENVIRONMENT=development
RECOMMENDER__PATHS__DATA_DIR=/app/data
RECOMMENDER__PATHS__ARTIFACT_DIR=/app/artifacts
RECOMMENDER__PATHS__REPORT_DIR=/app/reports
# Optional integrations
MLFLOW_TRACKING_URI=http://mlflow:5000
REDIS_URL=redis://redis:6379/0
POSTGRES_DSN=postgresql://recommender:change-me@postgres:5432/recommender
# Supply a deployment-specific random salt through a secret manager.
USER_ID_HASH_SALT=replace-at-deploy-time
